<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Login — Manofox SEO Hub</title>
<link href="https://fonts.googleapis.com/css2?family=Space+Mono:wght@400;700&family=Syne:wght@400;600;700;800&display=swap" rel="stylesheet">
<style>
:root{--bg:#0a0a0f;--surface:#111118;--border:#1e1e2a;--accent:#ff5c00;--accent2:#ff9a3c;--text:#e8e8f0;--muted:#6b6b7e;--mono:'Space Mono',monospace;--sans:'Syne',sans-serif;}
*{box-sizing:border-box;margin:0;padding:0;}
body{background:var(--bg);color:var(--text);font-family:var(--sans);min-height:100vh;display:flex;align-items:center;justify-content:center;}
.login-wrap{width:100%;max-width:400px;padding:20px;}
.login-card{background:var(--surface);border:1px solid var(--border);border-radius:16px;padding:44px;position:relative;overflow:hidden;}
.login-card::before{content:'';position:absolute;top:0;left:0;right:0;height:3px;background:linear-gradient(90deg,var(--accent),var(--accent2));}
.logo{font-size:2rem;font-weight:800;text-align:center;margin-bottom:8px;}
.logo span{color:var(--accent);}
.subtitle{text-align:center;color:var(--muted);font-family:var(--mono);font-size:0.75rem;margin-bottom:36px;}
.error{background:rgba(239,68,68,0.1);border:1px solid rgba(239,68,68,0.3);color:#ef4444;padding:12px 16px;border-radius:8px;font-size:0.85rem;margin-bottom:20px;}
label{display:block;font-family:var(--mono);font-size:0.7rem;color:var(--muted);text-transform:uppercase;letter-spacing:1px;margin-bottom:8px;}
input{width:100%;padding:14px 16px;background:#17171f;border:1px solid var(--border);border-radius:8px;color:var(--text);font-family:var(--sans);font-size:1rem;transition:0.2s;margin-bottom:20px;}
input:focus{outline:none;border-color:var(--accent);background:rgba(255,92,0,0.03);}
button{width:100%;padding:14px;background:var(--accent);color:white;border:none;border-radius:8px;font-family:var(--sans);font-weight:700;font-size:1rem;cursor:pointer;transition:0.2s;}
button:hover{background:var(--accent2);}
.footer-text{text-align:center;margin-top:20px;font-family:var(--mono);font-size:0.7rem;color:var(--muted);}
</style>
</head>
<body>
<div class="login-wrap">
    <div class="login-card">
        <div class="logo">Mano<span>fox</span>.</div>
        <div class="subtitle">SEO HUB · ADMIN PORTAL</div>
        <% if (error) { %><div class="error">⚠️ <%= error %></div><% } %>
        <form action="/login" method="POST">
            <label>Access Code</label>
            <input type="password" name="password" placeholder="Enter your password" required autofocus>
            <button type="submit">Unlock Dashboard →</button>
        </form>
        <div class="footer-text">© 2025 Manofox Digital · All rights reserved</div>
    </div>
</div>
</body>
</html>
