<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Add Site — Manofox SEO Hub</title>
<link href="https://fonts.googleapis.com/css2?family=Space+Mono:wght@400;700&family=Syne:wght@400;600;700;800&display=swap" rel="stylesheet">
<style>
:root{--bg:#0a0a0f;--surface:#111118;--surface2:#17171f;--border:#1e1e2a;--accent:#ff5c00;--accent2:#ff9a3c;--green:#00e88f;--text:#e8e8f0;--muted:#6b6b7e;--mono:'Space Mono',monospace;--sans:'Syne',sans-serif;}
*{box-sizing:border-box;margin:0;padding:0;}
body{background:var(--bg);color:var(--text);font-family:var(--sans);min-height:100vh;}
.header{display:flex;justify-content:space-between;align-items:center;padding:18px 40px;border-bottom:1px solid var(--border);background:rgba(10,10,15,0.95);}
.logo{font-weight:800;font-size:1.3rem;text-decoration:none;color:var(--text);}.logo span{color:var(--accent);}
.btn{font-family:var(--sans);font-weight:600;font-size:0.82rem;padding:8px 16px;border-radius:6px;border:none;cursor:pointer;text-decoration:none;transition:all 0.2s;}
.btn-ghost{background:transparent;color:var(--muted);border:1px solid var(--border);}.btn-ghost:hover{border-color:var(--accent);color:var(--text);}
.btn-primary{background:var(--accent);color:white;}.btn-primary:hover{background:var(--accent2);}

.main{padding:60px 40px;display:flex;justify-content:center;}
.form-wrap{width:100%;max-width:560px;}
.page-title{font-size:2rem;font-weight:800;margin-bottom:6px;}
.page-sub{color:var(--muted);font-family:var(--mono);font-size:0.8rem;margin-bottom:36px;}
.card{background:var(--surface);border:1px solid var(--border);border-radius:14px;padding:36px;position:relative;overflow:hidden;}
.card::before{content:'';position:absolute;top:0;left:0;right:0;height:2px;background:linear-gradient(90deg,var(--accent),var(--accent2));}
.error{background:rgba(239,68,68,0.1);border:1px solid rgba(239,68,68,0.3);color:#ef4444;padding:12px 16px;border-radius:8px;font-size:0.85rem;margin-bottom:20px;}

label{display:block;font-family:var(--mono);font-size:0.7rem;color:var(--muted);text-transform:uppercase;letter-spacing:1px;margin-bottom:8px;margin-top:20px;}
label:first-of-type{margin-top:0;}
input,select{width:100%;padding:13px 15px;background:var(--surface2);border:1px solid var(--border);border-radius:8px;color:var(--text);font-family:var(--sans);font-size:0.95rem;transition:0.2s;}
input:focus,select:focus{outline:none;border-color:var(--accent);}
.hint{font-family:var(--mono);font-size:0.7rem;color:var(--muted);margin-top:6px;}
.actions{display:flex;gap:12px;margin-top:28px;}

.cat-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:8px;margin-top:8px;}
.cat-option{
    padding:10px 8px;border-radius:8px;border:1px solid var(--border);
    background:transparent;color:var(--muted);font-family:var(--mono);font-size:0.7rem;
    cursor:pointer;text-align:center;transition:0.2s;
}
.cat-option:hover,.cat-option.selected{border-color:var(--accent);color:var(--text);background:rgba(255,92,0,0.08);}
</style>
</head>
<body>
<header class="header">
    <a href="/" class="logo">Mano<span>fox</span>. <span style="font-size:0.75rem;font-weight:400;color:var(--muted);">SEO Hub</span></a>
    <a href="/" class="btn btn-ghost">← Back</a>
</header>

<div class="main">
    <div class="form-wrap">
        <h1 class="page-title">Add New Site</h1>
        <p class="page-sub">Register a client site to manage its SEO and track traffic.</p>

        <div class="card">
            <% if (error) { %><div class="error">⚠️ <%= error %></div><% } %>
            <form action="/sites/new" method="POST" id="addForm">
                <label>Client / Site Name *</label>
                <input type="text" name="name" placeholder="e.g. Agrim Classes" required
                    oninput="updatePreview(this.value)">
                <div class="hint">Site ID will be: <span id="sid-preview" style="color:var(--accent);">—</span></div>

                <label>Domain</label>
                <input type="text" name="domain" placeholder="e.g. agrimclasses.com (optional)">

                <label>Category *</label>
                <input type="hidden" name="category" id="catInput" value="default">
                <div class="cat-grid">
                    <% categories.forEach(function(cat) { %>
                    <div class="cat-option <%= cat === 'default' ? 'selected' : '' %>"
                        onclick="selectCat('<%= cat %>', this)">
                        <%= {
                            education:'🎓 Education',
                            realestate:'🏠 Real Estate',
                            restaurant:'🍽️ Restaurant',
                            ecommerce:'🛒 E-commerce',
                            healthcare:'🏥 Healthcare',
                            technology:'💻 Technology',
                            fashion:'👗 Fashion',
                            fitness:'💪 Fitness',
                            travel:'✈️ Travel',
                            digitalmarketing:'📈 Marketing',
                            default:'🌐 General'
                        }[cat] || cat %>
                    </div>
                    <% }); %>
                </div>

                <div class="actions">
                    <button type="submit" class="btn btn-primary">🚀 Add Site & Generate SEO</button>
                    <a href="/" class="btn btn-ghost">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>

<script>
function updatePreview(name) {
    var sid = name.toLowerCase().replace(/\s+/g, '-').replace(/[^a-z0-9-]/g, '');
    document.getElementById('sid-preview').textContent = sid || '—';
}
function selectCat(cat, el) {
    document.querySelectorAll('.cat-option').forEach(e => e.classList.remove('selected'));
    el.classList.add('selected');
    document.getElementById('catInput').value = cat;
}
</script>
</body>
</html>
