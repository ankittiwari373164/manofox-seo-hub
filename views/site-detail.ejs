<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title><%= site.name %> — Manofox SEO Hub</title>
<link href="https://fonts.googleapis.com/css2?family=Space+Mono:wght@400;700&family=Syne:wght@400;600;700;800&display=swap" rel="stylesheet">
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
<style>
:root{--bg:#0a0a0f;--surface:#111118;--surface2:#17171f;--border:#1e1e2a;--accent:#ff5c00;--accent2:#ff9a3c;--green:#00e88f;--blue:#3b82f6;--red:#ef4444;--text:#e8e8f0;--muted:#6b6b7e;--mono:'Space Mono',monospace;--sans:'Syne',sans-serif;}
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0;}
body{background:var(--bg);color:var(--text);font-family:var(--sans);min-height:100vh;}
a{text-decoration:none;color:inherit;}
.header{display:flex;justify-content:space-between;align-items:center;padding:18px 40px;border-bottom:1px solid var(--border);position:sticky;top:0;z-index:100;background:rgba(10,10,15,0.97);backdrop-filter:blur(20px);}
.logo{font-weight:800;font-size:1.3rem;}.logo span{color:var(--accent);}
.btn{font-family:var(--sans);font-weight:600;font-size:0.82rem;padding:8px 16px;border-radius:6px;border:none;cursor:pointer;text-decoration:none;transition:all 0.2s;display:inline-flex;align-items:center;gap:6px;}
.btn-primary{background:var(--accent);color:white;}.btn-primary:hover{background:var(--accent2);}
.btn-ghost{background:transparent;color:var(--muted);border:1px solid var(--border);}.btn-ghost:hover{border-color:var(--accent);color:var(--text);}
.btn-green{background:rgba(0,232,143,0.1);color:var(--green);border:1px solid rgba(0,232,143,0.3);}
.btn-danger{background:rgba(239,68,68,0.1);color:var(--red);border:1px solid rgba(239,68,68,0.2);}
.main{padding:36px 40px;}
.breadcrumb{font-family:var(--mono);font-size:0.75rem;color:var(--muted);margin-bottom:20px;}
.breadcrumb a:hover{color:var(--accent);}
.page-hdr{display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:28px;flex-wrap:wrap;gap:16px;}
.page-title{font-size:2rem;font-weight:800;margin-bottom:6px;}
.page-domain{font-family:var(--mono);font-size:0.8rem;color:var(--muted);}
.page-domain span{color:var(--accent2);}
.tabs{display:flex;gap:4px;border-bottom:1px solid var(--border);margin-bottom:28px;}
.tab{font-family:var(--sans);font-weight:600;font-size:0.85rem;padding:10px 20px;cursor:pointer;border:none;background:transparent;color:var(--muted);border-bottom:2px solid transparent;transition:all 0.2s;}
.tab.active{color:var(--text);border-bottom-color:var(--accent);}
.tab-content{display:none;}.tab-content.active{display:block;}
.day-btn{font-family:var(--mono);font-size:0.75rem;padding:6px 12px;border-radius:6px;border:1px solid var(--border);background:transparent;color:var(--muted);cursor:pointer;text-decoration:none;transition:0.2s;margin-right:6px;}
.day-btn.active{background:var(--accent);color:white;border-color:var(--accent);}
.stats-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:16px;margin-bottom:24px;}
.stat-card{background:var(--surface);border:1px solid var(--border);border-radius:12px;padding:20px;position:relative;overflow:hidden;}
.stat-card::before{content:'';position:absolute;top:0;left:0;right:0;height:2px;background:linear-gradient(90deg,var(--accent),var(--accent2));}
.stat-label{font-family:var(--mono);font-size:0.65rem;color:var(--muted);text-transform:uppercase;letter-spacing:1px;margin-bottom:10px;}
.stat-value{font-size:1.8rem;font-weight:800;}
.stat-sub{font-size:0.75rem;color:var(--muted);margin-top:5px;}
.charts-row{display:grid;grid-template-columns:2fr 1fr;gap:16px;margin-bottom:24px;}
.chart-card{background:var(--surface);border:1px solid var(--border);border-radius:12px;padding:24px;}
.chart-title{font-weight:700;font-size:0.8rem;margin-bottom:20px;color:var(--muted);text-transform:uppercase;letter-spacing:1px;font-family:var(--mono);}
.chart-wrap{position:relative;height:220px;}
.data-row{display:grid;grid-template-columns:1fr 1fr;gap:16px;margin-bottom:24px;}
.table-card{background:var(--surface);border:1px solid var(--border);border-radius:12px;padding:24px;}
.table-title{font-weight:700;font-size:0.8rem;margin-bottom:16px;color:var(--muted);text-transform:uppercase;letter-spacing:1px;font-family:var(--mono);}
table{width:100%;border-collapse:collapse;font-size:0.88rem;}
th{text-align:left;padding:10px 12px;color:var(--muted);font-family:var(--mono);font-size:0.68rem;text-transform:uppercase;border-bottom:1px solid var(--border);}
td{padding:10px 12px;border-bottom:1px solid rgba(30,30,42,0.5);}
tr:last-child td{border-bottom:none;}
tr:hover td{background:var(--surface2);}
.num-cell{font-family:var(--mono);color:var(--green);font-weight:700;}
.seo-editor{background:var(--surface);border:1px solid var(--border);border-radius:12px;padding:28px;margin-bottom:20px;}
.editor-header{display:flex;justify-content:space-between;align-items:center;margin-bottom:24px;}
.editor-title{font-weight:700;font-size:1rem;}
.page-tab{font-family:var(--mono);font-size:0.75rem;padding:5px 12px;border-radius:6px;border:1px solid var(--border);background:transparent;color:var(--muted);cursor:pointer;text-decoration:none;transition:0.2s;margin-right:6px;margin-bottom:6px;display:inline-block;}
.page-tab.active,.page-tab:hover{background:var(--accent);color:white;border-color:var(--accent);}
label{display:block;font-family:var(--mono);font-size:0.7rem;color:var(--muted);text-transform:uppercase;letter-spacing:1px;margin-bottom:8px;margin-top:20px;}
label:first-of-type{margin-top:0;}
input[type=text],textarea,select{width:100%;padding:12px 14px;background:var(--surface2);border:1px solid var(--border);border-radius:8px;color:var(--text);font-family:var(--sans);font-size:0.9rem;transition:0.2s;resize:vertical;}
input[type=text]:focus,textarea:focus,select:focus{outline:none;border-color:var(--accent);}
textarea{min-height:80px;}
.keywords-display{width:100%;padding:12px 14px;background:var(--surface2);border:1px solid rgba(0,232,143,0.3);border-radius:8px;color:var(--green);font-family:var(--mono);font-size:0.78rem;min-height:60px;line-height:1.6;}
.add-page-form{display:flex;gap:10px;margin-top:16px;}
.add-page-form input{flex:1;}
/* Install tab */
.stack-panel{display:none;}.stack-panel.active{display:block;}
.snippet-card{background:var(--surface);border:1px solid var(--border);border-radius:12px;padding:24px;margin-bottom:16px;}
.snippet-title{font-weight:700;font-size:0.95rem;margin-bottom:10px;display:flex;align-items:center;gap:8px;flex-wrap:wrap;}
.snippet-sub{font-size:0.85rem;color:var(--muted);margin-bottom:14px;line-height:1.6;}
.code-block{background:var(--bg);border:1px solid var(--border);border-radius:8px;padding:16px;font-family:var(--mono);font-size:0.78rem;color:var(--accent2);white-space:pre;overflow-x:auto;margin-bottom:10px;line-height:1.7;}
.copy-btn{font-family:var(--mono);font-size:0.75rem;padding:6px 14px;border-radius:4px;border:1px solid var(--border);background:transparent;color:var(--muted);cursor:pointer;transition:0.2s;}
.copy-btn:hover{border-color:var(--green);color:var(--green);}
.badge{font-family:var(--mono);font-size:0.65rem;padding:3px 8px;border-radius:4px;}
.badge-green{background:rgba(0,232,143,0.1);color:var(--green);border:1px solid rgba(0,232,143,0.3);}
.badge-orange{background:rgba(255,154,60,0.15);color:var(--accent2);}
/* Keyword history */
.kw-item{padding:12px 0;border-bottom:1px solid var(--border);display:flex;gap:14px;align-items:flex-start;}
.kw-item:last-child{border-bottom:none;}
.kw-source{font-family:var(--mono);font-size:0.65rem;padding:3px 8px;border-radius:4px;white-space:nowrap;}
.src-google-trends{background:rgba(59,130,246,0.15);color:var(--blue);}
.src-fallback{background:rgba(107,107,126,0.2);color:var(--muted);}
.src-manual{background:rgba(0,232,143,0.1);color:var(--green);}
.kw-text{font-size:0.8rem;color:var(--muted);line-height:1.5;}
.kw-date{font-family:var(--mono);font-size:0.68rem;color:var(--muted);margin-top:3px;}
/* Settings */
.danger-zone{background:rgba(239,68,68,0.03);border:1px solid rgba(239,68,68,0.2);border-radius:12px;padding:24px;margin-top:20px;}
.danger-title{color:var(--red);font-weight:700;margin-bottom:8px;}
/* Toast */
.toast{position:fixed;bottom:24px;right:24px;background:var(--green);color:#000;font-weight:700;padding:12px 20px;border-radius:8px;font-size:0.9rem;z-index:9999;animation:slideUp 0.3s ease;}
@keyframes slideUp{from{transform:translateY(20px);opacity:0;}to{transform:translateY(0);opacity:1;}}
@media(max-width:900px){
  .header{padding:14px 16px;}.main{padding:20px 16px;}
  .stats-grid{grid-template-columns:1fr 1fr;}.charts-row,.data-row{grid-template-columns:1fr;}
}
</style>
</head>
<body>

<header class="header">
  <a href="/" class="logo">Mano<span>fox</span>. <span style="font-size:0.75rem;font-weight:400;color:var(--muted);">SEO Hub</span></a>
  <div style="display:flex;gap:10px;">
    <a href="/sites/<%= site.siteId %>/force-update" class="btn btn-green">⚡ Force Update</a>
    <a href="/sites/new" class="btn btn-primary">+ Add Site</a>
    <a href="/" class="btn btn-ghost">← Dashboard</a>
  </div>
</header>

<main class="main">
  <div class="breadcrumb"><a href="/">Dashboard</a> / <%= site.name %></div>

  <div class="page-hdr">
    <div>
      <h1 class="page-title"><%= site.name %></h1>
      <div class="page-domain">
        🌐 <span><%= site.domain || 'No domain set' %></span>
        &nbsp;·&nbsp; Category: <span><%= site.category || 'default' %></span>
      </div>
    </div>
    <% if(site.domain) { %>
    <a href="http://<%= site.domain %>" target="_blank" class="btn btn-ghost">🔗 Visit Site</a>
    <% } %>
  </div>

  <!-- TABS -->
  <div class="tabs">
    <button class="tab active" onclick="switchTab('analytics',this)">📊 Analytics</button>
    <button class="tab" onclick="switchTab('seo',this)">🔍 SEO Editor</button>
    <button class="tab" onclick="switchTab('install',this)">⚙️ Install</button>
    <button class="tab" onclick="switchTab('history',this)">📜 History</button>
    <button class="tab" onclick="switchTab('settings',this)">🔧 Settings</button>
  </div>

  <!-- ═══ ANALYTICS TAB ═══ -->
  <div id="tab-analytics" class="tab-content active">
    <div style="margin-bottom:20px;">
      <% [7,14,21,30].forEach(function(d){ %>
      <a href="/sites/<%= site.siteId %>?days=<%= d %>" class="day-btn <%= selectedDays==d?'active':'' %>"><%= d %>d</a>
      <% }); %>
    </div>

    <div class="stats-grid">
      <div class="stat-card">
        <div class="stat-label">Total Visits</div>
        <div class="stat-value" style="color:var(--green);"><%= totalVisits.toLocaleString() %></div>
        <div class="stat-sub">Last <%= selectedDays %> days</div>
      </div>
      <div class="stat-card">
        <div class="stat-label">Avg / Day</div>
        <div class="stat-value"><%= (totalVisits/selectedDays).toFixed(1) %></div>
        <div class="stat-sub">Daily average</div>
      </div>
      <div class="stat-card">
        <div class="stat-label">Top Device</div>
        <% var topDev = deviceStats.sort(function(a,b){return b.count-a.count;})[0]; %>
        <div class="stat-value" style="font-size:1.2rem;"><%= topDev ? topDev._id : '—' %></div>
        <div class="stat-sub"><%= topDev ? topDev.count+' visits' : 'No data yet' %></div>
      </div>
      <div class="stat-card">
        <div class="stat-label">Tracked Pages</div>
        <div class="stat-value"><%= pageStats.length %></div>
        <div class="stat-sub">Unique pages</div>
      </div>
    </div>

    <div class="charts-row">
      <div class="chart-card">
        <div class="chart-title">Traffic Trend</div>
        <div class="chart-wrap"><canvas id="trafficChart"></canvas></div>
      </div>
      <div class="chart-card">
        <div class="chart-title">Device Split</div>
        <div class="chart-wrap"><canvas id="deviceChart"></canvas></div>
      </div>
    </div>

    <div class="data-row">
      <div class="table-card">
        <div class="table-title">Top Referrers</div>
        <% if(referrerStats.length===0){ %>
        <p style="color:var(--muted);font-size:0.85rem;margin-top:12px;">No data yet.</p>
        <% } else { %>
        <table><tr><th>Source</th><th>Visits</th></tr>
        <% referrerStats.forEach(function(r){ %>
        <tr><td><%= r._id||'Direct' %></td><td class="num-cell"><%= r.count %></td></tr>
        <% }); %>
        </table><% } %>
      </div>
      <div class="table-card">
        <div class="table-title">Top Pages</div>
        <% if(pageStats.length===0){ %>
        <p style="color:var(--muted);font-size:0.85rem;margin-top:12px;">No data yet.</p>
        <% } else { %>
        <table><tr><th>Page</th><th>Visits</th></tr>
        <% pageStats.forEach(function(p){ %>
        <tr><td>/<%= p._id %></td><td class="num-cell"><%= p.count %></td></tr>
        <% }); %>
        </table><% } %>
      </div>
    </div>
  </div>

  <!-- ═══ SEO EDITOR TAB ═══ -->
  <div id="tab-seo" class="tab-content">
    <div style="margin-bottom:20px;">
      <div style="font-family:var(--mono);font-size:0.72rem;color:var(--muted);margin-bottom:10px;text-transform:uppercase;">Pages</div>
      <% seoPages.forEach(function(p,i){ %>
      <a href="#" class="page-tab <%= i===0?'active':'' %>" onclick="loadPage('<%= p.page %>',this);return false;">/<%= p.page %></a>
      <% }); %>
      <form action="/sites/<%= site.siteId %>/pages" method="POST" class="add-page-form">
        <input type="text" name="page" placeholder="New page slug (e.g. about, contact)" required>
        <button type="submit" class="btn btn-ghost">+ Add Page</button>
      </form>
    </div>

    <% seoPages.forEach(function(seoPage,idx){ %>
    <div class="seo-editor page-editor" id="editor-<%= seoPage.page %>" style="<%= idx>0?'display:none;':'' %>">
      <div class="editor-header">
        <div class="editor-title">Editing: /<%= seoPage.page %></div>
        <div style="font-family:var(--mono);font-size:0.7rem;color:var(--muted);">Updated: <%= new Date(seoPage.updatedAt).toLocaleString('en-IN') %></div>
      </div>
      <form action="/sites/<%= site.siteId %>/seo" method="POST">
        <input type="hidden" name="page" value="<%= seoPage.page %>">
        <label>Page Title</label>
        <input type="text" name="title" value="<%= seoPage.title||'' %>" maxlength="70">
        <label>Meta Description</label>
        <textarea name="description" rows="3" maxlength="200"><%= seoPage.description||'' %></textarea>
        <label>Keywords (Auto-updated by Robot 🤖)</label>
        <div class="keywords-display"><%= seoPage.keywords||'No keywords yet — click Force Update' %></div>
        <label>Robots</label>
        <select name="robots">
          <option value="index, follow" <%= seoPage.robots==='index, follow'?'selected':'' %>>index, follow</option>
          <option value="noindex, nofollow" <%= seoPage.robots==='noindex, nofollow'?'selected':'' %>>noindex, nofollow</option>
          <option value="index, nofollow" <%= seoPage.robots==='index, nofollow'?'selected':'' %>>index, nofollow</option>
        </select>
        <div style="margin-top:20px;display:flex;gap:10px;">
          <button type="submit" class="btn btn-primary">💾 Save Changes</button>
          <a href="/sites/<%= site.siteId %>/force-update" class="btn btn-ghost">⚡ Refresh Keywords</a>
        </div>
      </form>
    </div>
    <% }); %>

    <% if(seoPages.length===0){ %>
    <div style="text-align:center;padding:60px;color:var(--muted);">
      <div style="font-size:2.5rem;margin-bottom:12px;">📄</div>
      <div>No pages yet. Add a page above.</div>
    </div>
    <% } %>
  </div>

  <!-- ═══ INSTALL TAB ═══ -->
  <div id="tab-install" class="tab-content">
    <!-- Stack selector -->
    <div style="margin-bottom:20px;">
      <div style="font-family:var(--mono);font-size:0.72rem;color:var(--muted);margin-bottom:12px;text-transform:uppercase;">Choose your stack</div>
      <div style="display:flex;gap:8px;flex-wrap:wrap;">
        <button class="page-tab active" onclick="showStack('html',this)">🌐 HTML</button>
        <button class="page-tab" onclick="showStack('nodejs',this)">🟢 Node.js / EJS</button>
        <button class="page-tab" onclick="showStack('php',this)">🐘 PHP / Hostinger</button>
        <button class="page-tab" onclick="showStack('nextjs',this)">⚛️ Next.js</button>
      </div>
    </div>

    <!-- HTML -->
    <div id="stack-html" class="stack-panel active">
      <div class="snippet-card">
        <div class="snippet-title">🌐 HTML / Static Sites <span class="badge badge-orange">JS updates tags</span></div>
        <div class="snippet-sub">Paste inside &lt;head&gt; on every page. Fallback tags show in view-source; script refreshes with live keywords every 7 hours.</div>
        <div class="code-block" id="code-html"></div>
        <button class="copy-btn" onclick="copyCode('code-html',this)">📋 Copy</button>
      </div>
      <div class="snippet-card" style="border-color:rgba(255,154,60,0.3);">
        <div class="snippet-title">💡 Need keywords in view-source?</div>
        <div class="snippet-sub">Switch to the <strong>PHP / Hostinger</strong> tab — just rename .html → .php and paste the snippet. Keywords appear in view-source instantly ✅</div>
      </div>
    </div>

    <!-- Node.js -->
    <div id="stack-nodejs" class="stack-panel">
      <div class="snippet-card" style="border-color:rgba(0,232,143,0.3);">
        <div class="snippet-title">🟢 Node.js / EJS — 3 Steps <span class="badge badge-green">✅ Keywords in view-source</span></div>
        <div class="snippet-sub">Keywords are fetched on the server before HTML is sent — Google sees them perfectly.</div>
      </div>
      <div class="snippet-card">
        <div class="snippet-title">Step 1 — Helper function in server.js</div>
        <div class="snippet-sub">Paste this once above your routes.</div>
        <div class="code-block" id="code-helper"></div>
        <button class="copy-btn" onclick="copyCode('code-helper',this)">📋 Copy</button>
      </div>
      <div class="snippet-card">
        <div class="snippet-title">Step 2 — Update every route</div>
        <div class="code-block" id="code-routes"></div>
        <button class="copy-btn" onclick="copyCode('code-routes',this)">📋 Copy</button>
      </div>
      <div class="snippet-card">
        <div class="snippet-title">Step 3 — Replace &lt;head&gt; tags in ALL .ejs files</div>
        <div class="code-block" id="code-ejs"></div>
        <button class="copy-btn" onclick="copyCode('code-ejs',this)">📋 Copy</button>
      </div>
    </div>

    <!-- PHP -->
    <div id="stack-php" class="stack-panel">
      <div class="snippet-card" style="border-color:rgba(0,232,143,0.3);">
        <div class="snippet-title">🐘 PHP / Hostinger <span class="badge badge-green">✅ Keywords in view-source</span></div>
        <div class="snippet-sub"><strong>2 steps:</strong> Rename index.html → index.php &nbsp;·&nbsp; Paste code below at line 1 of file. Hostinger supports PHP by default — no setup needed.</div>
      </div>
      <div class="snippet-card">
        <div class="snippet-title">Paste at top of every .php file</div>
        <div class="code-block" id="code-php"></div>
        <button class="copy-btn" onclick="copyCode('code-php',this)">📋 Copy</button>
      </div>
      <div class="snippet-card" style="background:var(--surface2);">
        <div class="snippet-title">📁 Files to rename on Hostinger</div>
        <div style="font-family:var(--mono);font-size:0.8rem;line-height:2.2;color:var(--muted);">
          index.html → index.php &nbsp;·&nbsp; about.html → about.php<br>
          contact.html → contact.php &nbsp;·&nbsp; services.html → services.php
        </div>
      </div>
    </div>

    <!-- Next.js -->
    <div id="stack-nextjs" class="stack-panel">
      <div class="snippet-card">
        <div class="snippet-title">Option A — _document.js (all pages via script)</div>
        <div class="code-block" id="code-nextjs-a"></div>
        <button class="copy-btn" onclick="copyCode('code-nextjs-a',this)">📋 Copy</button>
      </div>
      <div class="snippet-card">
        <div class="snippet-title">Option B — Per page server-side <span class="badge badge-green">✅ Best SEO</span></div>
        <div class="code-block" id="code-nextjs-b"></div>
        <button class="copy-btn" onclick="copyCode('code-nextjs-b',this)">📋 Copy</button>
      </div>
    </div>

    <!-- How it works -->
    <div class="snippet-card" style="border-color:rgba(59,130,246,0.3);margin-top:8px;">
      <div class="snippet-title">💡 How It Works</div>
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-top:14px;">
        <div style="background:var(--surface2);border-radius:8px;padding:14px;"><strong>1️⃣ One-time setup</strong><div style="font-size:0.8rem;color:var(--muted);margin-top:4px;">Add snippet to client site. Takes 2 minutes.</div></div>
        <div style="background:var(--surface2);border-radius:8px;padding:14px;"><strong>2️⃣ Meta injected</strong><div style="font-size:0.8rem;color:var(--muted);margin-top:4px;">Title, description, keywords, OG tags on every page.</div></div>
        <div style="background:var(--surface2);border-radius:8px;padding:14px;"><strong>3️⃣ Traffic tracked</strong><div style="font-size:0.8rem;color:var(--muted);margin-top:4px;">Visits, device, referrer logged. Bots filtered out.</div></div>
        <div style="background:var(--surface2);border-radius:8px;padding:14px;"><strong>4️⃣ Auto-updates</strong><div style="font-size:0.8rem;color:var(--muted);margin-top:4px;">Every 7h, trending keywords pushed to all pages.</div></div>
      </div>
    </div>
  </div>

  <!-- ═══ HISTORY TAB ═══ -->
  <div id="tab-history" class="tab-content">
    <div class="snippet-card">
      <div class="table-title">Keyword Update History</div>
      <% if(keywordHistory.length===0){ %>
      <p style="color:var(--muted);font-size:0.85rem;margin-top:16px;">No updates yet. Click Force Update to start.</p>
      <% } else { %>
      <% keywordHistory.forEach(function(log){ %>
      <div class="kw-item">
        <div>
          <span class="kw-source src-<%= log.source %>">
            <%= log.source==='google-trends'?'📈 Google Trends': log.source==='manual'?'✏️ Manual':'⚡ Fallback' %>
          </span>
          <div class="kw-date"><%= new Date(log.date).toLocaleString('en-IN') %></div>
        </div>
        <div class="kw-text"><%= log.keywords %></div>
      </div>
      <% }); %>
      <% } %>
    </div>
  </div>

  <!-- ═══ SETTINGS TAB ═══ -->
  <div id="tab-settings" class="tab-content">
    <div class="seo-editor">
      <div class="editor-title" style="margin-bottom:20px;">Site Settings</div>
      <form action="/sites/<%= site.siteId %>/update-settings" method="POST">
        <label>Site Name</label>
        <input type="text" name="name" value="<%= site.name %>">
        <label>Domain</label>
        <input type="text" name="domain" value="<%= site.domain||'' %>" placeholder="e.g. agrimclasses.com">
        <label>Category</label>
        <select name="category">
          <% ['education','realestate','restaurant','ecommerce','healthcare','technology','fashion','fitness','travel','digitalmarketing','default'].forEach(function(cat){ %>
          <option value="<%= cat %>" <%= site.category===cat?'selected':'' %>><%= cat %></option>
          <% }); %>
        </select>
        <div style="margin-top:20px;">
          <button type="submit" class="btn btn-primary">💾 Save Settings</button>
        </div>
      </form>
    </div>
    <div class="danger-zone">
      <div class="danger-title">⚠️ Danger Zone</div>
      <div style="font-size:0.85rem;color:var(--muted);margin-bottom:16px;">Permanently deletes all SEO data, traffic, and keyword history for this site.</div>
      <form action="/sites/<%= site.siteId %>/delete" method="POST" onsubmit="return confirm('Delete this site? Cannot be undone.')"
        <button type="submit" class="btn btn-danger">🗑️ Delete Site</button>
      </form>
    </div>
  </div>
</main>

<script>
// ── All code snippets built safely in JS — zero EJS nesting issues ────────────
var HUB  = '<%= hubUrl %>';
var SID  = '<%= site.siteId %>';
var NAME = '<%= site.name %>';

var SNIPPETS = {
  'code-html': [
    '<!-- Manofox SEO Hub — paste inside <head> -->',
    '<meta name="description" content="Best services in India">',
    '<meta name="keywords" content="services, india, best">',
    '<meta name="robots" content="index, follow">',
    '<script src="' + HUB + '/seo.js?site=' + SID + '" defer><\/script>'
  ].join('\n'),

  'code-helper': [
    '// STEP 1 — Add this helper to your server.js (above routes)',
    '',
    "const SEO_HUB = '" + HUB + "';",
    '',
    "async function getSeo(page) {",
    "    page = page || 'home';",
    "    try {",
    "        const r    = await fetch(SEO_HUB + '/api/seo/" + SID + "?page=' + page);",
    "        const data = await r.json();",
    "        return {",
    "            title:       data.title         || '" + NAME + "',",
    "            description: data.description   || 'Welcome to " + NAME + "',",
    "            keywords:    data.keywords      || 'services, india',",
    "            robots:      data.robots        || 'index, follow',",
    "            ogTitle:     data.ogTitle       || data.title || '" + NAME + "',",
    "            ogDesc:      data.ogDescription || ''",
    "        };",
    "    } catch (e) {",
    "        return { title: '" + NAME + "', description: 'Welcome', keywords: 'services', robots: 'index, follow' };",
    "    }",
    "}"
  ].join('\n'),

  'code-routes': [
    '// STEP 2 — Call getSeo() in every route',
    '',
    "app.get('/', async (req, res) => {",
    "    const seo = await getSeo('home');",
    "    res.render('index', { seo });",
    "});",
    '',
    "app.get('/about', async (req, res) => {",
    "    const seo = await getSeo('about');",
    "    res.render('about', { seo });",
    "});",
    '',
    "app.get('/contact', async (req, res) => {",
    "    const seo = await getSeo('contact');",
    "    res.render('contact', { seo });",
    "});",
    '',
    "// Add more routes the same way..."
  ].join('\n'),

  'code-ejs': [
    '<!-- STEP 3 — Replace <head> tags in ALL .ejs files -->',
    '',
    "<title><%= seo ? seo.title : '" + NAME + "' %><\/title>",
    '<meta name="description" content="<%= seo ? seo.description : \'Welcome\' %>">',
    '<meta name="keywords"    content="<%= seo ? seo.keywords : \'services\' %>">',
    '<meta name="robots"      content="<%= seo ? seo.robots : \'index, follow\' %>">',
    "<meta property=\"og:title\" content=\"<%= seo ? seo.ogTitle : '" + NAME + "' %>\">",
    '',
    '<!-- Keywords now appear in view-source ✅ -->'
  ].join('\n'),

  'code-php': [
    '<?php',
    '/* RENAME: index.html -> index.php | PASTE at TOP of file (line 1) */',
    '',
    "$hub  = '" + HUB + "';",
    "$page = trim(parse_url($_SERVER['REQUEST_URI'], PHP_URL_PATH), '/') ?: 'home';",
    "$page = pathinfo($page, PATHINFO_FILENAME);",
    "if ($page === 'index') $page = 'home';",
    'try {',
    "    $json = @file_get_contents($hub . '/api/seo/" + SID + "?page=' . urlencode($page));",
    '    $seo  = $json ? json_decode($json, true) : [];',
    '} catch(Exception $e) { $seo = []; }',
    '',
    "$title  = htmlspecialchars($seo['title']       ?? '" + NAME + "');",
    "$desc   = htmlspecialchars($seo['description'] ?? 'Welcome to " + NAME + "');",
    "$keys   = htmlspecialchars($seo['keywords']    ?? 'services, india');",
    "$robots = htmlspecialchars($seo['robots']      ?? 'index, follow');",
    '?>',
    '<!DOCTYPE html>',
    '<html lang="en">',
    '<head>',
    '    <meta charset="UTF-8">',
    '    <title><?= $title ?></title>',
    '    <meta name="description" content="<?= $desc ?>">',
    '    <meta name="keywords"    content="<?= $keys ?>">',
    '    <meta name="robots"      content="<?= $robots ?>">',
    '    <!-- your CSS links below -->'
  ].join('\n'),

  'code-nextjs-a': [
    "// pages/_document.js",
    "import { Html, Head, Main, NextScript } from 'next/document'",
    'export default function Document() {',
    '  return (',
    '    <Html lang="en"><Head>',
    "      <script src='" + HUB + "/seo.js?site=" + SID + "' defer />",
    '    </Head><body><Main /><NextScript /></body></Html>',
    '  )',
    '}'
  ].join('\n'),

  'code-nextjs-b': [
    "// pages/index.js — server-side (keywords in view-source)",
    "import Head from 'next/head'",
    'export async function getServerSideProps() {',
    "    const res = await fetch('" + HUB + "/api/seo/" + SID + "?page=home');",
    '    const seo = await res.json();',
    '    return { props: { seo } };',
    '}',
    'export default function Home({ seo }) {',
    '    return (<><Head>',
    '        <title>{seo.title}</title>',
    '        <meta name="description" content={seo.description} />',
    '        <meta name="keywords" content={seo.keywords} />',
    '    </Head></>);',
    '}'
  ].join('\n')
};

// Fill all code blocks from JS
Object.keys(SNIPPETS).forEach(function(id) {
  var el = document.getElementById(id);
  if (el) el.textContent = SNIPPETS[id];
});

// ── Tab switching ─────────────────────────────────────────────────────────────
function switchTab(id, el) {
  document.querySelectorAll('.tab-content').forEach(function(t){ t.classList.remove('active'); });
  document.querySelectorAll('.tab').forEach(function(t){ t.classList.remove('active'); });
  document.getElementById('tab-'+id).classList.add('active');
  el.classList.add('active');
}

// ── Stack switching ───────────────────────────────────────────────────────────
function showStack(id, el) {
  document.querySelectorAll('.stack-panel').forEach(function(p){ p.classList.remove('active'); });
  document.getElementById('stack-'+id).classList.add('active');
  el.closest('#tab-install').querySelectorAll('.page-tab').forEach(function(t){ t.classList.remove('active'); });
  el.classList.add('active');
}

// ── SEO page switching ────────────────────────────────────────────────────────
function loadPage(pageName, el) {
  document.querySelectorAll('.page-editor').forEach(function(e){ e.style.display='none'; });
  document.querySelectorAll('.page-tab').forEach(function(e){ e.classList.remove('active'); });
  var ed = document.getElementById('editor-'+pageName);
  if (ed) ed.style.display = 'block';
  el.classList.add('active');
}

// ── Copy code ─────────────────────────────────────────────────────────────────
function copyCode(blockId, btn) {
  var text = document.getElementById(blockId).textContent;
  navigator.clipboard.writeText(text).then(function() {
    var orig = btn.textContent;
    btn.textContent = '✅ Copied!';
    btn.style.color = 'var(--green)';
    setTimeout(function(){ btn.textContent=orig; btn.style.color=''; }, 2000);
  });
}

// ── Toast on save ─────────────────────────────────────────────────────────────
if (window.location.search.includes('saved=1')) {
  var t = document.createElement('div');
  t.className = 'toast'; t.textContent = '✅ Saved successfully!';
  document.body.appendChild(t);
  setTimeout(function(){ t.remove(); }, 3000);
  history.replaceState(null,'',window.location.pathname);
}

// ── Charts ────────────────────────────────────────────────────────────────────
var daily   = <%- JSON.stringify(dailyStats) %>;
var devices = <%- JSON.stringify(deviceStats) %>;

Chart.defaults.color = '#6b6b7e';
Chart.defaults.borderColor = '#1e1e2a';

new Chart(document.getElementById('trafficChart'), {
  type: 'line',
  data: {
    labels: daily.map(function(d){ return d._id; }),
    datasets: [{
      label: 'Visits',
      data: daily.map(function(d){ return d.count; }),
      borderColor: '#ff5c00', backgroundColor: 'rgba(255,92,0,0.08)',
      borderWidth: 2.5, fill: true, tension: 0.4,
      pointBackgroundColor: '#ff5c00', pointRadius: 4
    }]
  },
  options: {
    maintainAspectRatio: false,
    plugins: { legend: { display: false } },
    scales: { y: { beginAtZero: true, grid: { color: '#1e1e2a' } }, x: { grid: { display: false } } }
  }
});

new Chart(document.getElementById('deviceChart'), {
  type: 'doughnut',
  data: {
    labels: devices.map(function(d){ return d._id; }),
    datasets: [{ data: devices.map(function(d){ return d.count; }), backgroundColor: ['#ff5c00','#00e88f','#3b82f6'], borderWidth: 0 }]
  },
  options: {
    maintainAspectRatio: false, cutout: '72%',
    plugins: { legend: { position: 'bottom', labels: { color: '#e8e8f0', padding: 16 } } }
  }
});
</script>
</body>
</html>
