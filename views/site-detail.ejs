<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title><%= site.name %> — Manofox SEO Hub</title>
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
<style>
*{box-sizing:border-box;margin:0;padding:0;}
body{background:#0a0a0f;color:#e8e8f0;font-family:'Segoe UI',sans-serif;min-height:100vh;}
a{color:inherit;text-decoration:none;}
.hdr{display:flex;justify-content:space-between;align-items:center;padding:16px 32px;border-bottom:1px solid #1e1e2a;background:#0a0a0f;position:sticky;top:0;z-index:99;}
.logo{font-weight:800;font-size:1.2rem;}.logo span{color:#ff5c00;}
.btn{padding:7px 16px;border-radius:6px;border:none;cursor:pointer;font-size:0.82rem;font-weight:600;display:inline-block;transition:0.2s;text-decoration:none;}
.btn-o{background:#ff5c00;color:#fff;}.btn-o:hover{background:#ff9a3c;}
.btn-g{background:transparent;border:1px solid #1e1e2a;color:#6b6b7e;}.btn-g:hover{border-color:#ff5c00;color:#e8e8f0;}
.btn-green{background:rgba(0,232,143,0.1);color:#00e88f;border:1px solid rgba(0,232,143,0.3);}
.btn-red{background:rgba(239,68,68,0.1);color:#ef4444;border:1px solid rgba(239,68,68,0.2);}
.main{padding:32px;}
.bread{font-size:0.78rem;color:#6b6b7e;margin-bottom:18px;}
.bread a:hover{color:#ff5c00;}
.page-hdr{display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:24px;flex-wrap:wrap;gap:12px;}
.page-title{font-size:1.8rem;font-weight:800;margin-bottom:4px;}
.page-sub{font-size:0.82rem;color:#6b6b7e;}
.page-sub span{color:#ff9a3c;}
.tabs{display:flex;gap:4px;border-bottom:1px solid #1e1e2a;margin-bottom:24px;overflow-x:auto;}
.tab{padding:10px 18px;cursor:pointer;border:none;background:transparent;color:#6b6b7e;font-size:0.85rem;font-weight:600;border-bottom:2px solid transparent;white-space:nowrap;transition:0.2s;}
.tab.active{color:#e8e8f0;border-bottom-color:#ff5c00;}
.tab-pane{display:none;}.tab-pane.active{display:block;}
.day-btn{font-size:0.75rem;padding:5px 12px;border-radius:6px;border:1px solid #1e1e2a;background:transparent;color:#6b6b7e;cursor:pointer;text-decoration:none;margin-right:6px;transition:0.2s;}
.day-btn.active,.day-btn:hover{background:#ff5c00;color:#fff;border-color:#ff5c00;}
.stats{display:grid;grid-template-columns:repeat(4,1fr);gap:14px;margin:20px 0;}
.stat{background:#111118;border:1px solid #1e1e2a;border-radius:10px;padding:18px;position:relative;overflow:hidden;}
.stat::before{content:'';position:absolute;top:0;left:0;right:0;height:2px;background:linear-gradient(90deg,#ff5c00,#ff9a3c);}
.stat-lbl{font-size:0.65rem;color:#6b6b7e;text-transform:uppercase;letter-spacing:1px;margin-bottom:8px;}
.stat-val{font-size:1.6rem;font-weight:800;}
.stat-sub{font-size:0.75rem;color:#6b6b7e;margin-top:4px;}
.charts{display:grid;grid-template-columns:2fr 1fr;gap:14px;margin-bottom:20px;}
.card{background:#111118;border:1px solid #1e1e2a;border-radius:10px;padding:20px;}
.card-title{font-size:0.7rem;color:#6b6b7e;text-transform:uppercase;letter-spacing:1px;margin-bottom:16px;}
.chart-wrap{position:relative;height:200px;}
.data-row{display:grid;grid-template-columns:1fr 1fr;gap:14px;margin-bottom:20px;}
table{width:100%;border-collapse:collapse;font-size:0.85rem;}
th{text-align:left;padding:8px 12px;color:#6b6b7e;font-size:0.68rem;text-transform:uppercase;border-bottom:1px solid #1e1e2a;}
td{padding:8px 12px;border-bottom:1px solid rgba(30,30,42,0.5);}
tr:last-child td{border-bottom:none;}
.num{font-weight:700;color:#00e88f;}
.empty{color:#6b6b7e;font-size:0.85rem;padding:16px 0;}
/* SEO editor */
.editor{background:#111118;border:1px solid #1e1e2a;border-radius:10px;padding:24px;margin-bottom:16px;}
.editor-hdr{display:flex;justify-content:space-between;align-items:center;margin-bottom:20px;}
.editor-title{font-weight:700;}
.editor-date{font-size:0.72rem;color:#6b6b7e;}
.pg-tab{font-size:0.75rem;padding:5px 12px;border-radius:6px;border:1px solid #1e1e2a;background:transparent;color:#6b6b7e;cursor:pointer;text-decoration:none;margin:0 4px 8px 0;display:inline-block;transition:0.2s;}
.pg-tab.active,.pg-tab:hover{background:#ff5c00;color:#fff;border-color:#ff5c00;}
label{display:block;font-size:0.7rem;color:#6b6b7e;text-transform:uppercase;letter-spacing:1px;margin:16px 0 6px;}
label:first-child{margin-top:0;}
input[type=text],textarea,select{width:100%;padding:10px 12px;background:#17171f;border:1px solid #1e1e2a;border-radius:6px;color:#e8e8f0;font-size:0.88rem;transition:0.2s;}
input[type=text]:focus,textarea:focus,select:focus{outline:none;border-color:#ff5c00;}
textarea{min-height:75px;resize:vertical;}
.kw-box{width:100%;padding:10px 12px;background:#17171f;border:1px solid rgba(0,232,143,0.3);border-radius:6px;color:#00e88f;font-size:0.78rem;min-height:55px;line-height:1.6;}
.add-pg{display:flex;gap:8px;margin-top:14px;}
.add-pg input{flex:1;}
/* Install */
.stack-panel{display:none;}.stack-panel.show{display:block;}
.snip-card{background:#111118;border:1px solid #1e1e2a;border-radius:10px;padding:20px;margin-bottom:14px;}
.snip-title{font-weight:700;font-size:0.92rem;margin-bottom:8px;display:flex;align-items:center;gap:8px;flex-wrap:wrap;}
.snip-sub{font-size:0.83rem;color:#6b6b7e;margin-bottom:12px;line-height:1.6;}
.code{background:#0a0a0f;border:1px solid #1e1e2a;border-radius:6px;padding:14px;font-family:'Courier New',monospace;font-size:0.76rem;color:#ff9a3c;white-space:pre;overflow-x:auto;margin-bottom:8px;line-height:1.7;}
.copy-btn{font-size:0.72rem;padding:5px 12px;border-radius:4px;border:1px solid #1e1e2a;background:transparent;color:#6b6b7e;cursor:pointer;transition:0.2s;}
.copy-btn:hover{border-color:#00e88f;color:#00e88f;}
.badge-g{background:rgba(0,232,143,0.1);color:#00e88f;border:1px solid rgba(0,232,143,0.3);font-size:0.65rem;padding:2px 8px;border-radius:4px;}
.badge-o{background:rgba(255,154,60,0.15);color:#ff9a3c;font-size:0.65rem;padding:2px 8px;border-radius:4px;}
/* History */
.kw-row{padding:12px 0;border-bottom:1px solid #1e1e2a;display:flex;gap:12px;align-items:flex-start;}
.kw-row:last-child{border-bottom:none;}
.src-badge{font-size:0.65rem;padding:2px 8px;border-radius:4px;white-space:nowrap;}
.src-google-trends{background:rgba(59,130,246,0.15);color:#3b82f6;}
.src-fallback{background:rgba(107,107,126,0.2);color:#6b6b7e;}
.src-manual{background:rgba(0,232,143,0.1);color:#00e88f;}
.kw-text{font-size:0.8rem;color:#6b6b7e;line-height:1.5;}
.kw-date{font-size:0.68rem;color:#6b6b7e;margin-top:2px;}
/* Settings */
.danger{background:rgba(239,68,68,0.03);border:1px solid rgba(239,68,68,0.2);border-radius:10px;padding:20px;margin-top:16px;}
.danger-title{color:#ef4444;font-weight:700;margin-bottom:6px;}
/* Toast */
.toast{position:fixed;bottom:20px;right:20px;background:#00e88f;color:#000;font-weight:700;padding:10px 18px;border-radius:8px;font-size:0.88rem;z-index:9999;}
@media(max-width:800px){.stats{grid-template-columns:1fr 1fr;}.charts,.data-row{grid-template-columns:1fr;}.hdr{padding:12px 16px;}.main{padding:16px;}}
</style>
</head>
<body>

<header class="hdr">
  <a href="/" class="logo">Mano<span>fox</span>. <span style="font-size:0.72rem;font-weight:400;color:#6b6b7e;">SEO Hub</span></a>
  <div style="display:flex;gap:8px;flex-wrap:wrap;">
    <a href="/sites/<%= site.siteId %>/force-update" class="btn btn-green">⚡ Update</a>
    <a href="/sites/new" class="btn btn-o">+ New Site</a>
    <a href="/" class="btn btn-g">← Back</a>
  </div>
</header>

<div class="main">
  <div class="bread"><a href="/">Dashboard</a> / <%= site.name %></div>

  <div class="page-hdr">
    <div>
      <div class="page-title"><%= site.name %></div>
      <div class="page-sub">🌐 <span><%= site.domain || 'No domain set' %></span> &nbsp;·&nbsp; Category: <span><%= site.category || 'default' %></span></div>
    </div>
    <% if(site.domain){ %>
    <a href="http://<%= site.domain %>" target="_blank" class="btn btn-g">🔗 Visit Site</a>
    <% } %>
  </div>

  <div class="tabs">
    <button class="tab active" onclick="showTab('analytics',this)">📊 Analytics</button>
    <button class="tab" onclick="showTab('seo',this)">🔍 SEO Editor</button>
    <button class="tab" onclick="showTab('install',this)">⚙️ Install</button>
    <button class="tab" onclick="showTab('history',this)">📜 History</button>
    <button class="tab" onclick="showTab('settings',this)">🔧 Settings</button>
  </div>

  <!-- ANALYTICS -->
  <div id="tab-analytics" class="tab-pane active">
    <div style="margin-bottom:18px;">
      <% [7,14,21,30].forEach(function(d){ %>
      <a href="/sites/<%= site.siteId %>?days=<%= d %>" class="day-btn <%= selectedDays==d ? 'active' : '' %>"><%= d %>d</a>
      <% }); %>
    </div>
    <div class="stats">
      <div class="stat">
        <div class="stat-lbl">Total Visits</div>
        <div class="stat-val" style="color:#00e88f;"><%= totalVisits %></div>
        <div class="stat-sub">Last <%= selectedDays %> days</div>
      </div>
      <div class="stat">
        <div class="stat-lbl">Avg / Day</div>
        <div class="stat-val"><%= (totalVisits/selectedDays).toFixed(1) %></div>
        <div class="stat-sub">Daily average</div>
      </div>
      <div class="stat">
        <div class="stat-lbl">Top Device</div>
        <% var topD = deviceStats.length > 0 ? deviceStats.sort(function(a,b){return b.count-a.count;})[0] : null; %>
        <div class="stat-val" style="font-size:1.1rem;"><%= topD ? topD._id : '—' %></div>
        <div class="stat-sub"><%= topD ? topD.count+' visits' : 'No data' %></div>
      </div>
      <div class="stat">
        <div class="stat-lbl">Pages Tracked</div>
        <div class="stat-val"><%= pageStats.length %></div>
        <div class="stat-sub">Unique pages</div>
      </div>
    </div>

    <div class="charts">
      <div class="card">
        <div class="card-title">Traffic Trend</div>
        <div class="chart-wrap"><canvas id="trafficChart"></canvas></div>
      </div>
      <div class="card">
        <div class="card-title">Device Split</div>
        <div class="chart-wrap"><canvas id="deviceChart"></canvas></div>
      </div>
    </div>

    <div class="data-row">
      <div class="card">
        <div class="card-title">Top Referrers</div>
        <% if(referrerStats.length===0){ %>
        <div class="empty">No data yet.</div>
        <% } else { %>
        <table>
          <tr><th>Source</th><th>Visits</th></tr>
          <% referrerStats.forEach(function(r){ %>
          <tr><td><%= r._id || 'Direct' %></td><td class="num"><%= r.count %></td></tr>
          <% }); %>
        </table>
        <% } %>
      </div>
      <div class="card">
        <div class="card-title">Top Pages</div>
        <% if(pageStats.length===0){ %>
        <div class="empty">No data yet.</div>
        <% } else { %>
        <table>
          <tr><th>Page</th><th>Visits</th></tr>
          <% pageStats.forEach(function(p){ %>
          <tr><td>/<%= p._id %></td><td class="num"><%= p.count %></td></tr>
          <% }); %>
        </table>
        <% } %>
      </div>
    </div>
  </div>

  <!-- SEO EDITOR -->
  <div id="tab-seo" class="tab-pane">
    <div style="margin-bottom:16px;">
      <div style="font-size:0.7rem;color:#6b6b7e;text-transform:uppercase;margin-bottom:8px;">Pages</div>
      <% seoPages.forEach(function(p,i){ %>
      <a href="#" class="pg-tab <%= i===0?'active':'' %>" onclick="loadPage('<%= p.page %>',this);return false;">/<%= p.page %></a>
      <% }); %>
      <form action="/sites/<%= site.siteId %>/pages" method="POST" class="add-pg">
        <input type="text" name="page" placeholder="New page slug e.g. about, contact" required>
        <button type="submit" class="btn btn-g">+ Add</button>
      </form>
    </div>

    <% if(seoPages.length===0){ %>
    <div style="text-align:center;padding:50px;color:#6b6b7e;">No pages yet. Add one above.</div>
    <% } %>

    <% seoPages.forEach(function(sp,i){ %>
    <div class="editor page-ed" id="ed-<%= sp.page %>" style="<%= i>0?'display:none':'display:block' %>">
      <div class="editor-hdr">
        <div class="editor-title">/<%= sp.page %></div>
        <div class="editor-date">Updated: <%= new Date(sp.updatedAt).toLocaleDateString('en-IN') %></div>
      </div>
      <form action="/sites/<%= site.siteId %>/seo" method="POST">
        <input type="hidden" name="page" value="<%= sp.page %>">
        <label>Title</label>
        <input type="text" name="title" value="<%= sp.title || '' %>" maxlength="70">
        <label>Description</label>
        <textarea name="description" rows="3" maxlength="200"><%= sp.description || '' %></textarea>
        <label>Keywords (Auto-updated by Robot)</label>
        <div class="kw-box"><%= sp.keywords || 'No keywords yet — click Force Update' %></div>
        <label>Robots</label>
        <select name="robots">
          <option value="index, follow" <%= sp.robots==='index, follow'?'selected':'' %>>index, follow</option>
          <option value="noindex, nofollow" <%= sp.robots==='noindex, nofollow'?'selected':'' %>>noindex, nofollow</option>
          <option value="index, nofollow" <%= sp.robots==='index, nofollow'?'selected':'' %>>index, nofollow</option>
        </select>
        <div style="margin-top:16px;display:flex;gap:8px;">
          <button type="submit" class="btn btn-o">💾 Save</button>
          <a href="/sites/<%= site.siteId %>/force-update" class="btn btn-g">⚡ Refresh Keywords</a>
        </div>
      </form>
    </div>
    <% }); %>
  </div>

  <!-- INSTALL -->
  <div id="tab-install" class="tab-pane">
    <div style="margin-bottom:18px;">
      <div style="font-size:0.7rem;color:#6b6b7e;text-transform:uppercase;margin-bottom:10px;">Choose your stack</div>
      <div style="display:flex;gap:6px;flex-wrap:wrap;">
        <button class="pg-tab active" onclick="showStack('html',this)">🌐 HTML</button>
        <button class="pg-tab" onclick="showStack('nodejs',this)">🟢 Node.js/EJS</button>
        <button class="pg-tab" onclick="showStack('php',this)">🐘 PHP/Hostinger</button>
        <button class="pg-tab" onclick="showStack('nextjs',this)">⚛️ Next.js</button>
      </div>
    </div>

    <div id="stack-html" class="stack-panel show">
      <div class="snip-card">
        <div class="snip-title">🌐 HTML / Static <span class="badge-o">JS updates tags</span></div>
        <div class="snip-sub">Paste inside &lt;head&gt; on every page. Fallback tags show in view-source; script refreshes keywords every 7 hours.</div>
        <div class="code" id="c-html">Loading...</div>
        <button class="copy-btn" onclick="doCopy('c-html',this)">📋 Copy</button>
      </div>
    </div>

    <div id="stack-nodejs" class="stack-panel">
      <div class="snip-card" style="border-color:rgba(0,232,143,0.3);">
        <div class="snip-title">🟢 Node.js/EJS — 3 Steps <span class="badge-g">✅ Keywords in view-source</span></div>
        <div class="snip-sub">Keywords fetched on server before HTML is sent. Google sees them perfectly.</div>
      </div>
      <div class="snip-card">
        <div class="snip-title">Step 1 — Helper in server.js</div>
        <div class="code" id="c-helper">Loading...</div>
        <button class="copy-btn" onclick="doCopy('c-helper',this)">📋 Copy</button>
      </div>
      <div class="snip-card">
        <div class="snip-title">Step 2 — Update every route</div>
        <div class="code" id="c-routes">Loading...</div>
        <button class="copy-btn" onclick="doCopy('c-routes',this)">📋 Copy</button>
      </div>
      <div class="snip-card">
        <div class="snip-title">Step 3 — Replace &lt;head&gt; in ALL .ejs files</div>
        <div class="code" id="c-ejs">Loading...</div>
        <button class="copy-btn" onclick="doCopy('c-ejs',this)">📋 Copy</button>
      </div>
    </div>

    <div id="stack-php" class="stack-panel">
      <div class="snip-card" style="border-color:rgba(0,232,143,0.3);">
        <div class="snip-title">🐘 PHP/Hostinger <span class="badge-g">✅ Keywords in view-source</span></div>
        <div class="snip-sub"><strong>2 steps:</strong> Rename .html → .php &nbsp;·&nbsp; Paste code below at line 1 of every file.</div>
      </div>
      <div class="snip-card">
        <div class="snip-title">Paste at top of every .php file</div>
        <div class="code" id="c-php">Loading...</div>
        <button class="copy-btn" onclick="doCopy('c-php',this)">📋 Copy</button>
      </div>
    </div>

    <div id="stack-nextjs" class="stack-panel">
      <div class="snip-card">
        <div class="snip-title">Option A — _document.js (all pages)</div>
        <div class="code" id="c-nxa">Loading...</div>
        <button class="copy-btn" onclick="doCopy('c-nxa',this)">📋 Copy</button>
      </div>
      <div class="snip-card">
        <div class="snip-title">Option B — Per page server-side <span class="badge-g">✅ Best SEO</span></div>
        <div class="code" id="c-nxb">Loading...</div>
        <button class="copy-btn" onclick="doCopy('c-nxb',this)">📋 Copy</button>
      </div>
    </div>
  </div>

  <!-- HISTORY -->
  <div id="tab-history" class="tab-pane">
    <div class="card">
      <div class="card-title">Keyword Update History</div>
      <% if(keywordHistory.length===0){ %>
      <div class="empty">No updates yet. Click Force Update.</div>
      <% } else { %>
      <% keywordHistory.forEach(function(log){ %>
      <div class="kw-row">
        <div>
          <span class="src-badge src-<%= log.source %>"><%= log.source==='google-trends'?'📈 Trends':log.source==='manual'?'✏️ Manual':'⚡ Fallback' %></span>
          <div class="kw-date"><%= new Date(log.date).toLocaleString('en-IN') %></div>
        </div>
        <div class="kw-text"><%= log.keywords %></div>
      </div>
      <% }); %>
      <% } %>
    </div>
  </div>

  <!-- SETTINGS -->
  <div id="tab-settings" class="tab-pane">
    <div class="editor">
      <div class="editor-hdr"><div class="editor-title">Site Settings</div></div>
      <form action="/sites/<%= site.siteId %>/update-settings" method="POST">
        <label>Site Name</label>
        <input type="text" name="name" value="<%= site.name %>">
        <label>Domain</label>
        <input type="text" name="domain" value="<%= site.domain || '' %>" placeholder="agrimclasses.com">
        <label>Category</label>
        <select name="category">
          <% ['education','realestate','restaurant','ecommerce','healthcare','technology','fashion','fitness','travel','digitalmarketing','default'].forEach(function(cat){ %>
          <option value="<%= cat %>" <%= site.category===cat?'selected':'' %>><%= cat %></option>
          <% }); %>
        </select>
        <div style="margin-top:16px;">
          <button type="submit" class="btn btn-o">💾 Save Settings</button>
        </div>
      </form>
    </div>
    <div class="danger">
      <div class="danger-title">⚠️ Danger Zone</div>
      <div style="font-size:0.83rem;color:#6b6b7e;margin-bottom:14px;">Permanently deletes all data for this site.</div>
      <form action="/sites/<%= site.siteId %>/delete" method="POST" onsubmit="return confirm('Delete this site? This cannot be undone.')">
        <button type="submit" class="btn btn-red">🗑️ Delete Site</button>
      </form>
    </div>
  </div>
</div>

<script>
// Safe values passed from server — no complex EJS
var HUB = '<%= hubUrl %>';
var SID = '<%= site.siteId %>';
var NM  = '<%= site.name %>';

// Build all code snippets in JS only (no EJS inside JS strings)
document.getElementById('c-html').textContent = [
  '<!-- Manofox SEO Hub — paste in <head> -->',
  '<meta name="description" content="Best services in India">',
  '<meta name="keywords" content="services, india, best">',
  '<meta name="robots" content="index, follow">',
  '<script src="' + HUB + '/seo.js?site=' + SID + '" defer><\/script>'
].join('\n');

document.getElementById('c-helper').textContent = [
  '// Paste this above your routes in server.js',
  "const SEO_HUB = '" + HUB + "';",
  '',
  "async function getSeo(page) {",
  "    try {",
  "        const r = await fetch(SEO_HUB + '/api/seo/" + SID + "?page=' + (page||'home'));",
  "        return await r.json();",
  "    } catch(e) {",
  "        return { title: '" + NM + "', description: 'Welcome', keywords: 'services', robots: 'index, follow' };",
  "    }",
  "}"
].join('\n');

document.getElementById('c-routes').textContent = [
  "app.get('/', async (req, res) => {",
  "    const seo = await getSeo('home');",
  "    res.render('index', { seo });",
  "});",
  '',
  "app.get('/about', async (req, res) => {",
  "    const seo = await getSeo('about');",
  "    res.render('about', { seo });",
  "});",
  '',
  "app.get('/contact', async (req, res) => {",
  "    const seo = await getSeo('contact');",
  "    res.render('contact', { seo });",
  "});",
  "// Repeat for every route..."
].join('\n');

document.getElementById('c-ejs').textContent = [
  "<!-- In <head> of ALL your .ejs files -->",
  "<title><" + "%= seo ? seo.title : '" + NM + "' %" + "></title>",
