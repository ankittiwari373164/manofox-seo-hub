// Tab switching
function showTab(id, el) {
  document.querySelectorAll('.tab-pane').forEach(function(p){ p.classList.remove('active'); });
  document.querySelectorAll('.tab').forEach(function(t){ t.classList.remove('active'); });
  document.getElementById('tab-'+id).classList.add('active');
  el.classList.add('active');
}

// Stack switching
function showStack(id, el) {
  document.querySelectorAll('.stack-panel').forEach(function(p){ p.classList.remove('show'); });
  document.getElementById('stack-'+id).classList.add('show');
  el.closest('#tab-install').querySelectorAll('.pg-tab').forEach(function(t){ t.classList.remove('active'); });
  el.classList.add('active');
}

// SEO page switching
function loadPage(name, el) {
  document.querySelectorAll('.page-ed').forEach(function(e){ e.style.display='none'; });
  el.closest('#tab-seo').querySelectorAll('.pg-tab').forEach(function(t){ t.classList.remove('active'); });
  var ed = document.getElementById('ed-'+name);
  if(ed) ed.style.display = 'block';
  el.classList.add('active');
}

// Copy code
function doCopy(id, btn) {
  navigator.clipboard.writeText(document.getElementById(id).textContent).then(function(){
    var o = btn.textContent;
    btn.textContent = '✅ Copied!';
    btn.style.color = '#00e88f';
    setTimeout(function(){ btn.textContent=o; btn.style.color=''; }, 2000);
  });
}

// Save toast
if(window.location.search.indexOf('saved=1') > -1) {
  var t = document.createElement('div');
  t.className = 'toast';
  t.textContent = '✅ Saved!';
  document.body.appendChild(t);
  setTimeout(function(){ t.remove(); }, 3000);
  history.replaceState(null,'',window.location.pathname);
}

// Charts
var daily   = <%- JSON.stringify(dailyStats) %>;
var devices = <%- JSON.stringify(deviceStats) %>;

Chart.defaults.color = '#6b6b7e';
Chart.defaults.borderColor = '#1e1e2a';

new Chart(document.getElementById('trafficChart'), {
  type: 'line',
  data: {
    labels: daily.map(function(d){ return d._id; }),
    datasets: [{
      label: 'Visits',
      data: daily.map(function(d){ return d.count; }),
      borderColor: '#ff5c00',
      backgroundColor: 'rgba(255,92,0,0.08)',
      borderWidth: 2, fill: true, tension: 0.4,
      pointBackgroundColor: '#ff5c00', pointRadius: 3
    }]
  },
  options: {
    maintainAspectRatio: false,
    plugins: { legend: { display: false } },
    scales: {
      y: { beginAtZero: true, grid: { color: '#1e1e2a' } },
      x: { grid: { display: false } }
    }
  }
});

new Chart(document.getElementById('deviceChart'), {
  type: 'doughnut',
  data: {
    labels: devices.map(function(d){ return d._id; }),
    datasets: [{
      data: devices.map(function(d){ return d.count; }),
      backgroundColor: ['#ff5c00','#00e88f','#3b82f6'],
      borderWidth: 0
    }]
  },
  options: {
    maintainAspectRatio: false,
    cutout: '70%',
    plugins: { legend: { position: 'bottom', labels: { color: '#e8e8f0', padding: 14 } } }
  }
});
</script>
